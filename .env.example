# Backend (backend/.env)
# Copy to backend/.env and set values

# MongoDB Atlas — get from: Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/trade_the_news?retryWrites=true&w=majority

# Voyage AI — https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_EMBEDDING_DIMENSIONS=1024

# OpenAI (optional; for LLM analysis only)
OPENAI_API_KEY=sk-your-openai-api-key

PORT=4000
STARTING_BALANCE=100000
NEXT_EVENT_INTERVAL_MS=60000

# Frontend (optional; defaults to http://localhost:4000)
# NEXT_PUBLIC_API_URL=http://localhost:4000
