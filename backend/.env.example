PORT=4000
# For production: allow frontend origin (comma-separated if multiple)
# CORS_ORIGIN=https://your-app.vercel.app

# MongoDB Atlas (replace with your cluster connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/trade_the_news?retryWrites=true&w=majority

# Voyage AI (for embeddings) — https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_EMBEDDING_DIMENSIONS=1024

# OpenAI (for LLM analysis only; optional)
OPENAI_API_KEY=sk-your-openai-api-key

NEXT_EVENT_INTERVAL_MS=60000
STARTING_BALANCE=100000
